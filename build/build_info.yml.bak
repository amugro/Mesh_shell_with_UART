cmake:
  board:
    name: 'nrf54l15dk'
    path:
     - 'C:/ncs/v3.2.1/zephyr/boards/nordic/nrf54l15dk'
    qualifiers: 'nrf54l15/cpuapp/ns'
    revision: ''
  images:
   - name: 'Mesh_shell_with_UART'
     source-dir: 'C:/myfw/mesh_test/Mesh_shell_with_UART'
     type: 'MAIN'
  kconfig:
    files:
     - 'C:/myfw/mesh_test/Mesh_shell_with_UART/build/_sysbuild/empty.conf'
     - 'c:/myfw/mesh_test/Mesh_shell_with_UART/sysbuild.conf'
    user-files:
     - 'c:/myfw/mesh_test/Mesh_shell_with_UART/sysbuild.conf'
version: '0.1.0'
west:
  command: 'C:\ncs\toolchains\66cdf9b75e\opt\bin\Scripts\west build --build-dir c:/myfw/mesh_test/Mesh_shell_with_UART/build c:/myfw/mesh_test/Mesh_shell_with_UART --pristine --board nrf54l15dk/nrf54l15/cpuapp/ns -- -DDEBUG_THREAD_INFO=On -DCONFIG_DEBUG_THREAD_INFO=y -Dmesh_shell_DEBUG_THREAD_INFO=On'
  topdir: 'c:\ncs\v3.2.1'
  version: '1.4.0'
